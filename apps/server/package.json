{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "plans:renewal": "bun run src/plans-renewal.ts",
    "snapshots:weekly": "bun run src/snapshots-weekly.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@corex/api": "workspace:*",
    "@corex/auth": "workspace:*",
    "@corex/db": "workspace:*",
    "@corex/env": "workspace:*",
    "@hono/trpc-server": "^0.4.0",
    "@trpc/server": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@corex/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}
