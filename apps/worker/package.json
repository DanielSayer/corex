{
  "name": "worker",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile worker",
    "dev": "bun run --hot src/index.ts",
    "job:weekly-plan-renewal": "bun run src/run-weekly-plan-renewal.ts",
    "job:weekly-snapshots": "bun run src/run-weekly-snapshots.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@corex/api": "workspace:*",
    "@corex/env": "workspace:*"
  },
  "devDependencies": {
    "@corex/config": "workspace:*",
    "@types/bun": "catalog:",
    "tsdown": "^0.16.5",
    "typescript": "^5"
  }
}
