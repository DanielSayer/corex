{
  "name": "corex",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@trpc/server": "^11.7.2",
      "better-auth": "1.5.2",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "sonner": "^2.0.5",
      "@trpc/client": "^11.7.2",
      "@types/react": "^19.2.10",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "test": "bun run test:unit && bun run test:integration",
    "test:watch": "bun test --watch --preload ./tests/config/unit-preload.ts ./packages ./apps/server/src ./apps/web/src",
    "test:unit": "bun test --preload ./tests/config/unit-preload.ts ./packages ./apps/server/src ./apps/web/src",
    "test:integration": "bun run --cwd apps/tests test",
    "test:coverage": "bun test --coverage --preload ./tests/config/unit-preload.ts ./packages ./apps/server/src ./apps/web/src && bun test --coverage --preload ./apps/tests/src/setup.ts ./apps/tests/src",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @corex/db db:push",
    "db:studio": "turbo -F @corex/db db:studio",
    "db:generate": "turbo -F @corex/db db:generate",
    "db:migrate": "turbo -F @corex/db db:migrate",
    "db:start": "turbo -F @corex/db db:start",
    "db:watch": "turbo -F @corex/db db:watch",
    "db:stop": "turbo -F @corex/db db:stop",
    "db:down": "turbo -F @corex/db db:down"
  },
  "dependencies": {
    "@corex/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@corex/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.1.38"
}
